{
  "info": {
    "name": "Serverless API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://REPLACE-WITH-API-ID.execute-api.us-east-1.amazonaws.com/prod"
    },
    {
      "key": "userId",
      "value": "REPLACE-WITH-USER-ID"
    },
    {
      "key": "listId",
      "value": "REPLACE-WITH-LIST-ID"
    },
    {
      "key": "itemKey",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jose Guzman\",\n  \"email\": \"jose@example.com\"\n}"
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/{{userId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jose Updated\",\n  \"email\": \"jose.updated@example.com\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Lists",
      "item": [
        {
          "name": "Create List",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/{{userId}}/lists",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Groceries\",\n  \"description\": \"Weekly shopping list\"\n}"
            }
          }
        },
        {
          "name": "Get All Lists for User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}/lists"
          }
        },
        {
          "name": "Get List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}/lists/{{listId}}"
          }
        },
        {
          "name": "Update List",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/{{userId}}/lists/{{listId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Groceries Updated\",\n  \"description\": \"Updated shopping list\",\n  \"items\": {\n    \"1\": { \"text\": \"Buy milk\", \"done\": false },\n    \"2\": { \"text\": \"Buy eggs\", \"done\": true }\n  }\n}"
            }
          }
        },
        {
          "name": "Toggle Item",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/{{userId}}/lists/{{listId}}/items/{{itemKey}}"
          }
        },
        {
          "name": "Delete List",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/{{userId}}/lists/{{listId}}"
          }
        }
      ]
    }
  ]
}
